# Supabase - Nuevas claves API (ver: https://github.com/orgs/supabase/discussions/29260)
# La clave publicable reemplaza a SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://kltdktiqliipphcbtjfp.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Para el backend (NestJS) - Clave secreta (reemplaza a SERVICE_ROLE_KEY)
SUPABASE_URL=https://kltdktiqliipphcbtjfp.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxx

# OpenAI (para chatbot - Fase 5)
OPENAI_API_KEY=sk-xxxxx

# WhatsApp Business API (Fase 5)
WHATSAPP_API_TOKEN=xxxxx
WHATSAPP_PHONE_NUMBER_ID=xxxxx

# PayPal Invoicing API
# Modo: 'sandbox' para pruebas, 'live' para producción
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=xxxxx
PAYPAL_CLIENT_SECRET=xxxxx
# Email de la cuenta Business de PayPal (el que aparece en las facturas)
PAYPAL_INVOICER_EMAIL=empresa@fengxchange.com
# Nombre de la empresa que aparece en las facturas
PAYPAL_INVOICER_NAME=Feng Digital Service LLC.

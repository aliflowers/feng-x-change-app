{
 "extends": "../../tsconfig.json",
 "compilerOptions": {
  "jsx": "preserve",
  "lib": [
   "DOM",
   "DOM.Iterable",
   "ES2022"
  ],
  "module": "ESNext",
  "moduleResolution": "bundler",
  "noEmit": true,
  "resolveJsonModule": true,
  "allowJs": true,
  "incremental": true,
  "plugins": [
   {
    "name": "next"
   }
  ],
  "baseUrl": ".",
  "paths": {
   "@/*": [
    "./src/*"
   ],
   "@fengxchange/shared": [
    "../../packages/shared/src"
   ],
   "@fengxchange/shared/*": [
    "../../packages/shared/src/*"
   ]
  }
 },
 "include": [
  "next-env.d.ts",
  "**/*.ts",
  "**/*.tsx",
  ".next/types/**/*.ts"
 ],
 "exclude": [
  "node_modules"
 ]
}